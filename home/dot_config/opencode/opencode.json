{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "with-claude": {
      "npm": "@little_tale/opencode-with-claude",
      "models": {
        "haiku": {
          "name": "WithClaude Haiku",
          "attachment": false,
          "limit": {
            "context": 200000,
            "output": 8192
          },
          "capabilities": {
            "reasoning": false,
            "toolcall": true
          }
        },
        "sonnet": {
          "name": "WithClaude Sonnet",
          "attachment": false,
          "limit": {
            "context": 1000000,
            "output": 16384
          },
          "capabilities": {
            "reasoning": true,
            "toolcall": true
          }
        },
        "opus": {
          "name": "WithClaude Opus",
          "attachment": false,
          "limit": {
            "context": 1000000,
            "output": 16384
          },
          "capabilities": {
            "reasoning": true,
            "toolcall": true
          }
        }
      },
      "options": {
        "cliPath": "claude"
      }
    },
    "cursor": {
      "name": "Cursor"
    },
    "vercel": {
      "name": "Vercel",
      "env": ["V0_API_KEY", "VERCEL_API_KEY"],
      "options": {
        "baseURL": "https://api.v0.dev/v1"
      },
      "models": {
        "v0-1.0-md": {
          "name": "v0-1.0-md"
        }
      }
    },
    "google": {
      "name": "Google",
      "models": {
        "gemini-3-pro-high": {
          "name": "Gemini 3 Pro High (Antigravity)",
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-pro-medium": {
          "name": "Gemini 3 Pro Medium (Antigravity)",
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-pro-low": {
          "name": "Gemini 3 Pro Low (Antigravity)",
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-flash-lite": {
          "name": "Gemini 3 Flash Lite (Antigravity)",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "agent": {
    "implClaude": {
      "description": "Claude implementation executor for approved workflow tasks",
      "mode": "subagent",
      "hidden": false,
      "model": "with-claude/sonnet",
      "prompt": "Runtime-managed implClaude prompt. The installed package provides the latest bundled prompt content automatically.",
      "tools": {}
    },
    "planClaude": {
      "description": "Claude planning assistant for workflow task plans",
      "mode": "subagent",
      "hidden": false,
      "model": "with-claude/opus",
      "prompt": "Runtime-managed planClaude prompt. The installed package provides the latest bundled prompt content automatically.",
      "tools": {}
    },
    "reviewClaude": {
      "description": "Claude review assistant for implementation verification",
      "mode": "subagent",
      "hidden": false,
      "model": "with-claude/sonnet",
      "prompt": "Runtime-managed reviewClaude prompt. The installed package provides the latest bundled prompt content automatically.",
      "tools": {}
    }
  },
  "mcp": {
    "augment-context-engine": {
      "type": "local",
      "command": ["/Users/lecoqjacob/.cache/.bun/bin/auggie", "--mcp", "--mcp-auto-workspace"],
      "enabled": true
    },
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "enabled": true,
      "environment": {}
    },
    "stash": {
      "type": "remote",
      "url": "http://localhost:8080/sse",
      "enabled": true
    }
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter",
    "@tarquinen/opencode-dcp@latest",
    "@warp-dot-dev/opencode-warp",
    "opencode-cursor-oauth",
    "opencode-openai-codex-auth",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
