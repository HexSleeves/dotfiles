#!/usr/bin/env bash
set -euo pipefail

profile=""

while (($#)); do
  case "$1" in
    PROFILE=*)
      profile="${1#PROFILE=}"
      shift
      ;;
    --profile=*)
      profile="${1#--profile=}"
      shift
      ;;
    --profile)
      if (($# < 2)); then
        echo "Missing value for --profile" >&2
        exit 1
      fi
      profile="$2"
      shift 2
      ;;
    *)
      if [[ -z "$profile" ]]; then
        profile="$1"
      fi
      shift
      ;;
  esac
done

profile="${profile:-${PROFILE:-${AWS_PROFILE:-}}}"

if [[ -z "$profile" ]]; then
  echo "Missing AWS profile. Pass PROFILE=<name>, --profile <name>, or set AWS_PROFILE." >&2
  exit 1
fi

if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
  exit 0
fi

exec aws sso login --profile="$profile"
