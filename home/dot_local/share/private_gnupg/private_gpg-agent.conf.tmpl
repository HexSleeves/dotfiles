# Cache passphrase for 8 hours (28800 seconds)
default-cache-ttl 28800

# Maximum cache time of 8 hours, even if being actively used
max-cache-ttl 28800

# Enable passphrase preset (allows storing in keyring)
allow-preset-passphrase

# Allow automation to use --pinentry-mode loopback
allow-loopback-pinentry

{{- if eq .chezmoi.os "darwin" }}
pinentry-program {{ .homebrewprefix }}/bin/pinentry-mac
{{- else if eq .chezmoi.os "linux" }}
{{- if eq .homebrewprefix "" }}
pinentry-program /usr/bin/pinentry-curses
{{- else }}
pinentry-program {{ .homebrewprefix }}/bin/pinentry-curses
{{- end }}
{{- end }}
