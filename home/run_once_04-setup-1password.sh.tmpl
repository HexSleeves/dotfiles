#!/bin/bash
{{ if eq .chezmoi.os "darwin" }}

# Setup 1Password CLI
# Idempotent script to configure 1Password with biometric authentication

set -euo pipefail

echo "Setting up 1Password CLI..."

# Check if op is installed
if ! command -v op >/dev/null 2>&1; then
    echo "1Password CLI not found. Installing via Homebrew..."
    if command -v brew >/dev/null 2>&1; then
        brew install --cask 1password-cli
    else
        echo "Homebrew not found. Please install 1Password CLI manually:"
        echo "  https://developer.1password.com/docs/cli/get-started/"
        exit 1
    fi
fi

# Check if 1Password app is installed
if ! command -v "1Password" >/dev/null 2>&1 && [[ ! -d "/Applications/1Password.app" ]]; then
    echo ""
    echo "1Password desktop app not found."
    echo "The 1Password CLI works best with the desktop app for biometric authentication."
    echo ""
    echo "Install from: https://1password.com/downloads/"
    echo "Or via Homebrew: brew install --cask 1password"
    echo ""
    read -rp "Continue without desktop app? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi
fi

# Enable biometric authentication (recommended for macOS)
echo ""
echo "Configuring biometric authentication..."
echo "This allows 1Password CLI to use Touch ID for authentication."
echo ""

# Check if biometric is already enabled
BIOMETRIC_STATUS=$(op account list --format json 2>/dev/null | jq -r '.[0].biometric // empty' 2>/dev/null || echo "")

if [[ "$BIOMETRIC_STATUS" == "enabled" ]]; then
    echo "Biometric authentication already enabled."
else
    echo "To enable biometric authentication:"
    echo "  1. Open 1Password desktop app"
    echo "  2. Go to Preferences > Developer"
    echo "  3. Enable 'Touch ID' or 'Biometric unlock'"
    echo "  4. Run: op signin --account <account-shorthand>"
    echo ""
fi

# Check if already signed in
ACCOUNT_LIST=$(op account list --format json 2>/dev/null || echo "[]")
ACCOUNT_COUNT=$(echo "$ACCOUNT_LIST" | jq 'length')

if [[ "$ACCOUNT_COUNT" -eq 0 ]]; then
    echo ""
    echo "No 1Password accounts configured."
    echo "To add an account:"
    echo "  op account add --address <subdomain>.1password.com --email <email>"
    echo ""
    echo "Example:"
    echo "  op account add --address my.1password.com --email user@example.com"
    echo ""
    echo "After adding your account, sign in with:"
    echo "  eval \$(op signin)"
    echo ""
else
    echo ""
    echo "1Password accounts configured:"
    echo "$ACCOUNT_LIST" | jq -r '.[] | "  - \(.shorthand) (\(.email))"'
    echo ""
    
    # Check if we have an active session
    if op user list --format json >/dev/null 2>&1; then
        echo "✓ Active session detected. 1Password is ready to use with chezmoi!"
    else
        echo "No active session. Sign in with:"
        echo "  eval \$(op signin)"
        echo ""
        echo "Or use biometric authentication (if enabled):"
        echo "  op signin --biometric"
    fi
fi

echo ""
echo "1Password setup complete!"
echo ""
echo "You can now use 1Password with chezmoi templates:"
echo '  {{ "{{" }} onepasswordRead "op://vault/item/field" {{ "}}" }}'
echo '  {{ "{{" }} (onepassword "item-uuid").fields[0].value {{ "}}" }}'
echo ""
echo "Useful commands:"
echo "  op account list           - List configured accounts"
echo "  op signin                 - Sign in to your account"
echo "  op signout                - Sign out of your account"
echo "  op item get <item>        - Get an item by name or UUID"
echo "  just 1p                   - See all 1Password commands"
{{- else if eq .chezmoi.os "linux" }}

{{- $linuxFamilyByID := dict
  "ubuntu" "debian"
  "debian" "debian"
  "pop" "debian"
  "linuxmint" "debian"
  "elementary" "debian"
  "zorin" "debian"
  "arch" "arch"
  "manjaro" "arch"
  "endeavouros" "arch"
  "fedora" "rhel"
  "rhel" "rhel"
  "rocky" "rhel"
  "almalinux" "rhel"
  "centos" "rhel"
  "ol" "rhel"
-}}
{{- $distroFamily := .chezmoi.os -}}
{{- if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") -}}
{{-   $distroID := lower .chezmoi.osRelease.id -}}
{{-   if hasKey $linuxFamilyByID $distroID -}}
{{-     $distroFamily = index $linuxFamilyByID $distroID -}}
{{-   else -}}
{{-     $distroFamily = $distroID -}}
{{-   end -}}
{{- end -}}

# Setup 1Password CLI on Linux
# Uses biometric authentication or device authentication

set -euo pipefail

echo "Setting up 1Password CLI..."

ensure_deps() {
    local missing=()
    for cmd in jq unzip curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Installing missing dependencies: ${missing[*]}"
        DISTRO_FAMILY={{ $distroFamily | quote }}
        case "$DISTRO_FAMILY" in
            debian)
                sudo apt-get update && sudo apt-get install -y "${missing[@]}"
                ;;
            arch)
                sudo pacman -S --noconfirm --needed "${missing[@]}"
                ;;
            rhel)
                sudo dnf install -y "${missing[@]}"
                ;;
            *)
                echo "Unsupported distro family: $DISTRO_FAMILY"
                echo "Please install manually: ${missing[*]}"
                return 1
                ;;
        esac
    fi
}

install_op_rhel() {
    echo "Installing 1Password CLI via RPM repo..."
    sudo rpm --import https://downloads.1password.com/keys/1password.asc 2>/dev/null || true
    sudo mkdir -p /etc/yum.repos.d
    sudo tee /etc/yum.repos.d/1password.repo >/dev/null <<'REPO'
[1password]
name=1Password Stable Channel
baseurl=https://downloads.1password.com/linux/rpm/stable/$basearch
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://downloads.1password.com/keys/1password.asc
REPO
    sudo dnf install -y 1password-cli
}

install_op_debian() {
    echo "Installing 1Password CLI via APT repo..."
    curl -sS https://downloads.1password.com/keys/1password.asc | sudo gpg --dearmor --yes --output /usr/share/keyrings/1password-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" | sudo tee /etc/apt/sources.list.d/1password.list >/dev/null
    sudo apt-get update && sudo apt-get install -y 1password-cli
}

install_op_direct() {
    echo "Installing 1Password CLI via direct download..."
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) OP_ARCH="amd64" ;;
        aarch64|arm64) OP_ARCH="arm64" ;;
        *) echo "Unsupported architecture: $ARCH"; return 1 ;;
    esac

    OP_VERSION="2.30.3"
    local tmpdir
    tmpdir=$(mktemp -d)
    cd "$tmpdir"
    curl -sSfO "https://cache.agilebits.com/dist/1P/op2/pkg/v${OP_VERSION}/op_linux_${OP_ARCH}_v${OP_VERSION}.zip"
    unzip -o "op_linux_${OP_ARCH}_v${OP_VERSION}.zip" -d op
    sudo mv op/op /usr/local/bin/
    cd -
    rm -rf "$tmpdir"
}

# Ensure dependencies are available
if ! ensure_deps; then
    echo "ERROR: Could not install required dependencies (jq, unzip, curl)."
    echo "Please install them manually and re-run chezmoi apply."
    exit 1
fi

# Install op if not found
if ! command -v op >/dev/null 2>&1; then
    echo "1Password CLI not found. Installing..."
    DISTRO_FAMILY={{ $distroFamily | quote }}
    INSTALLED=false

    case "$DISTRO_FAMILY" in
        rhel)
            if install_op_rhel; then
                INSTALLED=true
            fi
            ;;
        debian)
            if install_op_debian; then
                INSTALLED=true
            fi
            ;;
    esac

    if [[ "$INSTALLED" == "false" ]]; then
        echo "Package repo install unavailable, trying direct download..."
        if ! install_op_direct; then
            echo ""
            echo "ERROR: Failed to install 1Password CLI automatically."
            echo "Please install manually:"
            echo "  https://developer.1password.com/docs/cli/get-started/"
            echo ""
            echo "Then re-run: chezmoi apply"
            exit 1
        fi
    fi
fi

# Verify installation
if ! command -v op >/dev/null 2>&1; then
    echo "ERROR: 1Password CLI installation failed."
    echo "Please install manually: https://developer.1password.com/docs/cli/get-started/"
    echo "Then re-run: chezmoi apply"
    exit 1
fi

echo "1Password CLI installed: $(op --version 2>/dev/null || echo 'unknown version')"

# Check if 1Password app is installed (optional on Linux)
if [[ ! -d "/opt/1Password" ]] && [[ ! -d "$HOME/.1password" ]]; then
    echo ""
    echo "Note: 1Password desktop app is recommended for biometric authentication."
    echo "Install from: https://1password.com/downloads/linux/"
    echo ""
fi

# Check if already signed in
ACCOUNT_LIST=$(op account list --format json 2>/dev/null || echo "[]")
ACCOUNT_COUNT=$(echo "$ACCOUNT_LIST" | jq 'length')

if [[ "$ACCOUNT_COUNT" -eq 0 ]]; then
    echo ""
    echo "No 1Password accounts configured."
    echo "To add an account:"
    echo "  op account add --address <subdomain>.1password.com --email <email>"
    echo ""
else
    echo ""
    echo "1Password accounts configured:"
    echo "$ACCOUNT_LIST" | jq -r '.[] | "  - \(.shorthand) (\(.email))"'
    echo ""

    # Check if we have an active session
    if op user list --format json >/dev/null 2>&1; then
        echo "Active session detected. 1Password is ready to use with chezmoi!"
    else
        echo "No active session. Sign in with:"
        echo "  eval \$(op signin)"
    fi
fi

echo ""
echo "1Password setup complete!"
echo ""
echo "You can now use 1Password with chezmoi templates:"
echo '  {{ "{{" }} onepasswordRead "op://vault/item/field" {{ "}}" }}'
echo '  {{ "{{" }} (onepassword "item-uuid").fields[0].value {{ "}}" }}'
{{- end }}