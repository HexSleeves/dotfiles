{{- $linuxFamilyByID := dict
  "ubuntu" "debian"
  "debian" "debian"
  "pop" "debian"
  "linuxmint" "debian"
  "elementary" "debian"
  "zorin" "debian"
  "arch" "arch"
  "manjaro" "arch"
  "endeavouros" "arch"
  "fedora" "rhel"
  "rhel" "rhel"
  "rocky" "rhel"
  "almalinux" "rhel"
  "centos" "rhel"
  "ol" "rhel"
-}}
{{- $distroFamily := .chezmoi.os -}}
{{- if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") -}}
{{-   $distroID := lower .chezmoi.osRelease.id -}}
{{-   if hasKey $linuxFamilyByID $distroID -}}
{{-     $distroFamily = index $linuxFamilyByID $distroID -}}
{{-   else -}}
{{-     $distroFamily = $distroID -}}
{{-   end -}}
{{- end -}}
{{- $packageManager := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $packageManager = "brew" -}}
{{- else if eq $distroFamily "debian" -}}
{{-   $packageManager = "apt-get" -}}
{{- else if eq $distroFamily "arch" -}}
{{-   $packageManager = "pacman" -}}
{{- else if eq $distroFamily "rhel" -}}
{{-   if lookPath "dnf" -}}
{{-     $packageManager = "dnf" -}}
{{-   else -}}
{{-     $packageManager = "yum" -}}
{{-   end -}}
{{- end -}}
#!/usr/bin/env bash
# Bootstrap package installation

set -euo pipefail

CURRENT_OS={{ .chezmoi.os | quote }}
CURRENT_DISTRO_FAMILY={{ $distroFamily | quote }}
CURRENT_PACKAGE_MANAGER={{ $packageManager | quote }}
ALLOW_UNPINNED_INSTALLERS="${CHEZMOI_ALLOW_UNPINNED_INSTALLERS:-0}"
BREWFILE_TARGET="{{ .chezmoi.homeDir }}/{{ .bootstrap.packages.darwin.brewfile }}"
BREWFILE_SOURCE="{{ .chezmoi.sourceDir }}/home/{{ .bootstrap.packages.darwin.brewfile }}"

DEBIAN_SYSTEM_PACKAGES=(
{{- range .bootstrap.packages.linux.debian.system }}
    {{ . | quote }}
{{- end }}
)
ARCH_SYSTEM_PACKAGES=(
{{- range .bootstrap.packages.linux.arch.system }}
    {{ . | quote }}
{{- end }}
)
RHEL_SYSTEM_PACKAGES=(
{{- range .bootstrap.packages.linux.rhel.system }}
    {{ . | quote }}
{{- end }}
)

log() {
    printf '%s\n' "$*"
}

warn() {
    printf 'WARN: %s\n' "$*" >&2
}

die() {
    printf 'ERROR: %s\n' "$*" >&2
    exit 1
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

install_homebrew_if_missing() {
    if have_command brew; then
        log "Homebrew already installed"
        return
    fi

    log "Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if have_command brew; then
        eval "$(brew shellenv)"
    fi
}

pkg_update() {
    case "$CURRENT_PACKAGE_MANAGER" in
        apt-get)
            sudo apt-get update
            ;;
        pacman)
            sudo pacman -Sy --noconfirm
            ;;
        dnf)
            sudo dnf makecache
            ;;
        yum)
            sudo yum makecache
            ;;
    esac
}

pkg_install() {
    [[ $# -gt 0 ]] || return 0

    case "$CURRENT_PACKAGE_MANAGER" in
        apt-get)
            sudo apt-get install -y "$@"
            ;;
        pacman)
            sudo pacman -S --noconfirm --needed "$@"
            ;;
        dnf)
            sudo dnf install -y "$@"
            ;;
        yum)
            sudo yum install -y "$@"
            ;;
        *)
            die "unsupported package manager: $CURRENT_PACKAGE_MANAGER"
            ;;
    esac
}

install_mise_if_missing() {
    if have_command mise; then
        log "mise already installed"
        return
    fi

    case "$CURRENT_PACKAGE_MANAGER" in
        brew)
            log "Installing mise with Homebrew"
            brew install mise
            ;;
        apt-get|pacman|dnf|yum)
            log "Installing mise with $CURRENT_PACKAGE_MANAGER"
            if ! pkg_install mise; then
                warn "mise is not available via $CURRENT_PACKAGE_MANAGER on this system"
            fi
            ;;
    esac

    if ! have_command mise; then
        if [[ "$ALLOW_UNPINNED_INSTALLERS" == "1" ]]; then
            log "Installing mise via official installer script"
            curl -fsSL https://mise.run | sh
        else
            warn "Skipping mise installer script. Set CHEZMOI_ALLOW_UNPINNED_INSTALLERS=1 to allow it."
        fi
    fi
}

install_rustup_if_missing() {
    if have_command rustup; then
        [[ -f "{{ .chezmoi.homeDir }}/.cargo/env" ]] && source "{{ .chezmoi.homeDir }}/.cargo/env"
        log "rustup already installed"
        return
    fi

    log "Installing rustup"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    [[ -f "{{ .chezmoi.homeDir }}/.cargo/env" ]] && source "{{ .chezmoi.homeDir }}/.cargo/env"
}

install_uv_if_missing() {
    if have_command uv; then
        log "uv already installed"
        return
    fi

    log "Installing uv"
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="{{ .chezmoi.homeDir }}/.local/bin:$PATH"
}

install_ruff_if_missing() {
    if have_command ruff; then
        log "ruff already installed"
        return
    fi

    if ! have_command uv; then
        warn "uv not found; skipping ruff install"
        return
    fi

    log "Installing ruff via uv"
    uv tool install ruff
}

install_cargo_binstall_if_missing() {
    if ! have_command cargo; then
        return
    fi
    if have_command cargo-binstall; then
        return
    fi

    log "Installing cargo-binstall with cargo"
    cargo install cargo-binstall
}

install_darwin_packages() {
    log "Detected macOS"

    if ! have_command git; then
        log "Installing Xcode Command Line Tools"
        xcode-select --install
        warn "Complete Xcode Command Line Tools installation, then re-run."
        exit 1
    fi

    install_homebrew_if_missing

    if [[ -f "$BREWFILE_TARGET" ]]; then
        log "Installing packages from $BREWFILE_TARGET"
        if ! brew bundle install --file="$BREWFILE_TARGET"; then
            warn "brew bundle failed; continuing bootstrap. Re-run manually with: brew bundle install --file=\"$BREWFILE_TARGET\""
        fi
    elif [[ -f "$BREWFILE_SOURCE" ]]; then
        log "Installing packages from $BREWFILE_SOURCE"
        if ! brew bundle install --file="$BREWFILE_SOURCE"; then
            warn "brew bundle failed; continuing bootstrap. Re-run manually with: brew bundle install --file=\"$BREWFILE_SOURCE\""
        fi
    else
        warn "No Brewfile found; skipping brew bundle"
    fi
}

install_linux_packages() {
    local packages=()

    case "$CURRENT_DISTRO_FAMILY" in
        debian)
            packages=("${DEBIAN_SYSTEM_PACKAGES[@]}")
            ;;
        arch)
            packages=("${ARCH_SYSTEM_PACKAGES[@]}")
            ;;
        rhel)
            packages=("${RHEL_SYSTEM_PACKAGES[@]}")
            ;;
        *)
            die "unsupported Linux distribution family: $CURRENT_DISTRO_FAMILY"
            ;;
    esac

    log "Detected Linux ($CURRENT_DISTRO_FAMILY)"
    pkg_update
    pkg_install "${packages[@]}"
}

install_fzf_key_bindings_if_missing() {
    local fzf_path

    [[ "$CURRENT_OS" == "darwin" ]] || return 0
    [[ ! -f "{{ .chezmoi.homeDir }}/.fzf.zsh" ]] || return 0
    have_command brew || return 0

    fzf_path="$(brew --prefix fzf 2>/dev/null || true)"
    [[ -n "$fzf_path" ]] || return 0

    "$fzf_path/install" --no-update-rc --completion --key-bindings
}

log "Bootstrapping packages for '{{ .class }}' profile"

case "$CURRENT_OS" in
    darwin)
        install_darwin_packages
        ;;
    linux)
        install_linux_packages
        ;;
    *)
        die "unsupported operating system: $CURRENT_OS"
        ;;
esac

install_mise_if_missing
install_rustup_if_missing
install_uv_if_missing
install_ruff_if_missing
install_cargo_binstall_if_missing
install_fzf_key_bindings_if_missing

log "Core package installation completed"
